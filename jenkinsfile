pipeline {
    agent any

    stages {
        stage('Fetch Code') {
            steps {
                git branch: 'main', changelog: false, poll: false, url: 'https://github.com/Sachin7490/htmlproject.git'
            }
        }
        stage('Install Apache') {
            steps {
                sh 'sudo apt install apache2 -y'
            }
        }
        
    }
}
